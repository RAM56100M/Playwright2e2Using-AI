# Base URL for the application under test
# Default: https://rahulshettyacademy.com/client
BASE_URL=https://rahulshettyacademy.com/client

# Environment
# Options: development, staging, production
ENVIRONMENT=development

# CI Flag
# Set to true when running in CI/CD pipeline
CI=false

# Playwright settings
BROWSERS=chromium,firefox,webkit
SLOW_MO=0
HEADED=false

# API endpoints (if testing APIs)
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=10000

# Logging
LOG_LEVEL=info
DEBUG=false
