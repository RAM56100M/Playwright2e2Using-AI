# Base URL for the application under test
# Default: https://rahulshettyacademy.com/client
BASE_URL=https://rahulshettyacademy.com/client

# Test account credentials
# Keep real values in .env or CI secrets, never in committed test files.
TEST_USER_EMAIL=your-test-user@example.com
TEST_USER_PASSWORD=replace-with-test-password
TEST_ADMIN_EMAIL=your-test-admin@example.com
TEST_ADMIN_PASSWORD=replace-with-test-admin-password

# Environment
# Options: development, staging, production
ENVIRONMENT=development

# CI Flag
# Set to true when running in CI/CD pipeline
CI=false

# Playwright settings
BROWSERS=chromium,firefox,webkit
SLOW_MO=0
HEADED=false

# API endpoints (if testing APIs)
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=10000

# Logging
LOG_LEVEL=info
DEBUG=false
